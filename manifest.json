{
  "manifest_version": 3,
  "name": "⚡ PK Chrome Shortcuts",
  "version": "0.21",
  "description": "Raccourcis Chrome: vue fractionnee simulee et detach d'onglet.",
  "permissions": [
    "tabs",
    "windows",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "detach-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Detacher l'onglet actif dans une nouvelle fenetre"
    },
    "split-active-tab-simulated": {
      "description": "Simuler un split view avec l'onglet actif"
    },
    "native-split-view": {
      "description": "Split View reel Chrome (raccourci natif Chrome: Cmd+Option+N)"
    },
    "navigate-last-active-tab": {
      "description": "Navigate to last active tab"
    },
    "toggle-pin-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Pin / unpin active tab"
    },
    "search-and-jump": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Search and jump"
    },
    "search-in-background": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Search in background"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
